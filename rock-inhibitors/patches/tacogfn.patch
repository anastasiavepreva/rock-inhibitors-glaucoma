+def add_conformer(mol):
+    # mol = Chem.AddHs(mol)
+    Chem.rdDistGeom.EmbedMolecule(mol)
+    if mol.GetNumConformers() == 0:
+        raise RuntimeError("Failed to generate conformer.")
+    return
+
+
+def mol_to_maccs(mol):
+    return [int(bit) for bit in MACCSkeys.GenMACCSKeys(mol).ToBitString()][:167]
+
+
+def mols_to_maccs(mols):
+    fps = [mol_to_maccs(mol) for mol in mols]
+    fps_array = np.array(fps, dtype=np.int32)
+    return fps_array
+
+
+def melanin(mols: list[RDMol], default=0):
+    path = "./melanin.pkl"
+    model = joblib.load(path)
+    fps = mols_to_maccs(mols)
+    mel = model.predict_proba(fps)
+    mel = mel[:, 1]
+    mel = torch.tensor(mel, dtype=torch.float32)
+    return mel
+
+
+def irritation(mols: list[RDMol], default=0):
+    path = "./irritation.pkl"
+    with open(path, 'rb') as f:
+        model = pickle.load(f)
+    fps = mols_to_maccs(mols)
+    irr = model.predict_proba(fps)
+    irr = irr[:, 1]
+    irr = 1 - torch.tensor(irr, dtype=torch.float32)
+    return irr
+
+
+def mol_to_descriptor(mol):
+    descriptor_names = list(rdMolDescriptors.Properties.GetAvailableProperties())
+    get_descriptors = rdMolDescriptors.Properties(descriptor_names)
+    descriptors = np.array(get_descriptors.ComputeProperties(mol))
+    return descriptors
+
+
+def corneal(mols: list[RDMol], default=0):
+    path = "./corneal.pkl"
+    model = joblib.load(path)
+    fps = np.array([mol_to_descriptor(mol) for mol in mols])
+    cor = model.predict_proba(fps)
+    cor = cor[:, 1]
+    cor = torch.tensor(cor, dtype=torch.float32)
+    return cor
+
